<% layout("layouts/boilerplate") -%>

    <body>
        <div class="cardR">
            <div class="card">
                <h1>
                    <%= user.tital %>
                </h1>
                <div class="image"> <img src="<%= user.image.url %>" alt="Listing Image"> </div>
                <p> Owned By <%=user.owner.username%>
                </p>
                <p>
                    <%= user.description %>
                </p>
                <p> ₹ <%= user.price.toLocaleString("en-IN") %>
                </p>
                <p>
                    <%= user.location %> | <%= user.country %>
                </p>
                <% if(currentUser) {%>
                    <div class="actions">
                        <form method="post" action="/listings/<%= user._id %>?_method=DELETE"> <button
                                class="delete-btn">Delete</button> </form>
                        <form method="get" action="/listings/<%= user._id %>/edit"> <button
                                class="edit-btn">Edit</button> </form>
                    </div>
                    <%}%>
            </div>
            <% if(currentUser) {%>
                <div class="card p-4">
                    <h1>Leave a Review</h1>
                    <form action="/listings/<%= user._id %>/reviews" method="post" class="needs-validation" novalidate>
                        <!-- <div> <label for="">Rating</label> <input type="range" min="1" max="5" name="review[rating]">
                        </div> -->
                        <fieldset class="starability-coinFlip">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                        <div> <label for="">Comment</label> <textarea name="review[Comment]" id="" cols="30" rows="1"
                                class="form-control" required></textarea>
                            <div class="invalid-feedback">Please add some comments for review.</div>
                        </div> <button class="btn btn-dark mt-3">Submit</button>
                    </form>
                </div>
                <%}%>
                    <div class="card p-4">

                        <h1>All reviews</h1>
                        <hr>
                        <% for(let review of user.reviews) {%>
                            <div>
                                <div class="rv">
                                    <h5>@<%= review.author.username%>
                                    </h5>
                                    <p class="starability-result" data-rating=<%=review.rating%>>
                                        Rated: 3 stars
                                    </p>
                                    <% if(currentUser) {%>
                                        <form method="post"
                                            action="/listings/<%= user._id %>/reviews/<%= review._id %>/delete?_method=DELETE">
                                            <button class="btn btn-dark">Delete</button>
                                        </form>
                                        <%}%>
                                </div>
                                <p>
                                    <%= review.Comment %>
                                </p>
                                <hr>
                            </div>
                            <% }%>
                    </div>
                    <hr>

        </div>
    </body>